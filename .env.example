# Airtable
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXX
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Nedarim Plus (נדרים פלוס)
# Mosad ID (7 digits) provided by Nedarim Plus
NEDARIM_TERMINAL_ID=your_mosad_id
# Static authentication text received from Nedarim Plus office
NEDARIM_API_VALID=your_api_valid_text

# Vercel Blob — for signature image storage
# Get this from your Vercel project settings > Storage > Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_XXXX

# App URL (used for payment callbacks)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
